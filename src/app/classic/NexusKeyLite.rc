#include "resource.h"
#include <windows.h>
#include "../../core/Version.h"

// Icon IDs (must match TrayIcon.cpp expectations)
#define IDI_APP              101
#define IDI_VIET_ON          102
#define IDI_VIET_OFF         103
#define IDI_VIET_ON_WHITE    104
#define IDI_VIET_OFF_WHITE   105
#define IDI_VIET_ON_BLACK    106
#define IDI_VIET_OFF_BLACK   107

// Icons — Color (default)
IDI_APP              ICON    "../resources/icon.ico"
IDI_VIET_ON          ICON    "../resources/status/StatusViet.ico"
IDI_VIET_OFF         ICON    "../resources/status/StatusEng.ico"
// Icons — White (for dark taskbar)
IDI_VIET_ON_WHITE    ICON    "../resources/status/StatusViet10.ico"
IDI_VIET_OFF_WHITE   ICON    "../resources/status/StatusEng10.ico"
// Icons — Black (for light taskbar)
IDI_VIET_ON_BLACK    ICON    "../resources/status/StatusVietBlack.ico"
IDI_VIET_OFF_BLACK   ICON    "../resources/status/StatusEngBlack.ico"

// Icons — Tab/button UI elements (color)
IDI_TAB_INPUT        ICON    "../resources/tabs/tab_input.ico"
IDI_TAB_MACROS       ICON    "../resources/tabs/tab_macros.ico"
IDI_TAB_SYSTEM       ICON    "../resources/tabs/tab_system.ico"
IDI_BTN_PICK         ICON    "../resources/tabs/btn_pick.ico"

// Version info
VS_VERSION_INFO VERSIONINFO
    FILEVERSION    NEXUSKEY_VERSION_RC
    PRODUCTVERSION NEXUSKEY_VERSION_RC
    FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
    FILEFLAGS      VS_FF_DEBUG
#else
    FILEFLAGS      0x0L
#endif
    FILEOS         VOS_NT_WINDOWS32
    FILETYPE       VFT_APP
    FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "Nguyenx"
            VALUE "FileDescription",  "Vipkey Classic - Vietnamese IME"
            VALUE "FileVersion",      NEXUSKEY_VERSION_STR
            VALUE "InternalName",     "VipkeyClassic"
            VALUE "LegalCopyright",   "GPL-3.0-only"
            VALUE "OriginalFilename", "VipkeyClassic.exe"
            VALUE "ProductName",      "Vipkey Classic"
            VALUE "ProductVersion",   NEXUSKEY_VERSION_STR
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END

// Visual styles manifest is provided via CMake target property
// (do NOT embed RT_MANIFEST here — MSVC auto-generates one, causing duplicates)
